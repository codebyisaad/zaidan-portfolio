# Copy to .env on your VPS: cp .env.example .env
# The deploy workflow never overwrites .env — create it once on the server.

# -----------------------------------------------------------------------------
# Site (required for Docker build + sitemap/canonical URLs)
# -----------------------------------------------------------------------------
# Trailing slash is fine. Used as Astro `site` and Docker build arg.
SITE_URL=https://arxiron.com/

# -----------------------------------------------------------------------------
# PostgreSQL (required)
# -----------------------------------------------------------------------------
# Used by the db service and to build DATABASE_URL for the portfolio app.
DB_USER=portfolio
DB_PASSWORD=change-me-strong-password
DB_NAME=portfolio_db

# Optional override (compose sets this automatically if omitted):
# DATABASE_URL=postgres://portfolio:change-me-strong-password@db:5432/portfolio_db

# -----------------------------------------------------------------------------
# Directus CMS (required for admin + site content from Directus)
# -----------------------------------------------------------------------------
# Public URL where you access Directus (reverse proxy / subdomain).
DIRECTUS_URL=https://admin.arxiron.com

# Random string — generate with: openssl rand -hex 32
DIRECTUS_SECRET=change-me-to-a-long-random-secret

DIRECTUS_ADMIN_EMAIL=zaidan@arxiron.com
DIRECTUS_ADMIN_PASSWORD=change-me-admin-password

# -----------------------------------------------------------------------------
# Guestbook email notifications (optional)
# -----------------------------------------------------------------------------
# If SMTP_USER and SMTP_PASS are empty, guestbook still saves to the DB but
# skips email. Defaults match Zoho SMTP.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# Analytics (optional — leave empty to disable)
# -----------------------------------------------------------------------------
# Injected in page HTML. Available at runtime via env_file in Docker.
UMAMI_WEBSITE_ID=
AHREFS_ANALYTICS_KEY=

# -----------------------------------------------------------------------------
# Set by docker-compose for the portfolio container (usually do not set in .env)
# -----------------------------------------------------------------------------
# DIRECTUS_INTERNAL_URL=http://directus:8055
# NODE_ENV=production
