# Copy to .env on your VPS: cp .env.example .env
# Deploy never overwrites .env on the server.

# -----------------------------------------------------------------------------
# Site (required for Docker build + sitemap/canonical URLs)
# -----------------------------------------------------------------------------
SITE_URL=

# -----------------------------------------------------------------------------
# PostgreSQL (required for guestbook only)
# -----------------------------------------------------------------------------
DB_USER=
DB_PASSWORD=
DB_NAME=

# -----------------------------------------------------------------------------
# Guestbook email notifications (optional)
# -----------------------------------------------------------------------------
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# Analytics (optional)
# -----------------------------------------------------------------------------
UMAMI_WEBSITE_ID=
AHREFS_ANALYTICS_KEY=
